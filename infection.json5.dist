{
    // Mutation testing (ADR-0006): runs weekly / on-demand, never blocks PR merges.
    "source": {
        "directories": ["src"],
        // Exclude side-effect-heavy layers (subprocess IO); focus on pure computation.
        "excludes": ["Console", "Mcp"]
    },
    "mutators": {
        "@default": true
    },
    // Load the project (root) autoloader in every Infection test process so the
    // app's Composer\InstalledVersions lookups (e.g. rector/rector) resolve —
    // the bin-namespace phpunit binary otherwise only sees its own installed.php.
    "bootstrap": "vendor/autoload.php",
    // PHPUnit lives in an isolated bamarni bin namespace (bin-links: false), and
    // its coverage run needs the relaxed config under build/ (see that file).
    "phpUnit": {
        "configDir": "build",
        "customPath": ".vendor-bin/phpunit/vendor/bin/phpunit"
    },
    // Run PHPStan (max + bleedingEdge + strict-rules, via the root phpstan.neon.dist)
    // on each ESCAPED mutant: a mutation that produces type-invalid / unreachable code
    // is "killed by static analysis", catching the defensive subprocess-parsing guards
    // that the test suite cannot reach. PHPStan lives in its own bamarni bin namespace.
    "staticAnalysisTool": "phpstan",
    "phpStan": {
        "configDir": ".",
        "customPath": ".vendor-bin/phpstan/vendor/bin/phpstan"
    },
    // Infection invokes PHPStan without its usual auto memory bump, so lift the
    // limit explicitly (max + bleedingEdge + strict-rules over src + tests).
    "staticAnalysisToolOptions": "--memory-limit=-1",
    "minMsi": 90,
    "minCoveredMsi": 95,
    "logs": {
        "text": "php://stderr"
    }
}
